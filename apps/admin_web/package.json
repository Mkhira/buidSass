{
  "name": "admin_web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "lint:i18n": "tsx tools/lint/no-hardcoded-strings.ts",
    "lint:rtl": "tsx tools/lint/no-physical-margins.ts",
    "lint:cache-locale": "tsx tools/lint/no-locale-leaky-cache.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:a11y": "playwright test --config=playwright.a11y.config.ts",
    "test:e2e": "playwright test --config=playwright.e2e.config.ts",
    "gen:api": "openapi-typescript ../../services/backend_api/openapi.json -o lib/api/types/index.ts",
    "catalog:check-permissions": "tsx scripts/check-permission-catalog.ts",
    "catalog:check-nav-manifest": "tsx scripts/check-nav-manifest.ts",
    "catalog:check-audit-redaction": "tsx scripts/check-audit-redaction.ts"
  },
  "dependencies": {

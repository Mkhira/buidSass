    "eslint-plugin-no-unsanitized": "^4.1.5",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.59.1",
    "postcss": "^8",
    "storybook": "^8.6.18",

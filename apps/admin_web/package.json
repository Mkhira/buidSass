    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "react": "^18",
    "react-arborist": "^3.5.0",
    "react-dom": "^18",
    "react-hook-form": "^7.74.0",
    "react-textarea-autosize": "^8.5.9",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",

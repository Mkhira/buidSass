<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.dtd">
<plist version="1.0">
<dict>
	<!--
		Universal-link receivers per contracts/deeplink-routes.md.
		Both prod and staging hosts are listed; the marketing site hosts
		apple-app-site-association under each host root.
		No custom URL scheme — FR-002a forbids it.
	-->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:dental-commerce.com</string>
		<string>applinks:staging.dental-commerce.com</string>
	</array>
</dict>
</plist>

{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "KeyVault": {
    "Uri": "https://kv-dental-prd.vault.azure.net/"
  },
  "Meilisearch": {
    "Url": "https://search.dental.example.com"
  },
  "Notifications": {
    "Mode": "Live"
  },
  "Payment": {
    "Mode": "Live"
  },
  "Seeding": {
    "Enabled": false,
    "AutoApply": false
  },
  "DataResidency": {
    "Region": "sa-central"
  },
  "OpenTelemetry": {
    "SamplingRatio": 0.05
  }
}

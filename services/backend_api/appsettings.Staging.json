{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "KeyVault": {
    "Uri": "https://kv-dental-stg.vault.azure.net/"
  },
  "Meilisearch": {
    "Url": "https://search-stg.dental.example.com"
  },
  "Notifications": {
    "Mode": "TestOnly"
  },
  "Payment": {
    "Mode": "Sandbox"
  },
  "Seeding": {
    "Enabled": true,
    "AutoApply": true,
    "DatasetSize": "medium"
  },
  "DataResidency": {
    "Region": "sa-central"
  },
  "OpenTelemetry": {
    "SamplingRatio": 1.0
  }
}

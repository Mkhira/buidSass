{
  "openapi": "3.0.3",
  "info": {
    "title": "Tax Invoices API",
    "version": "1.0.0",
    "description": "Spec 012 tax invoices v1 — bilingual AR/EN PDF, ZATCA Phase 1 QR, credit notes."
  },
  "paths": {
    "/v1/customer/orders/{orderId}/invoice.pdf": {
      "get": {
        "summary": "Download the customer's invoice PDF (FR-006)",
        "parameters": [{ "name": "orderId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "PDF stream", "content": { "application/pdf": {} } },
          "401": { "description": "invoice.requires_auth" },
          "404": { "description": "invoice.not_found" },
          "409": { "description": "invoice.render_pending (with Retry-After)" },
          "503": { "description": "invoice.blob_unavailable" }
        }
      }
    },
    "/v1/customer/orders/{orderId}/invoice": {
      "get": {
        "summary": "Invoice metadata only",
        "parameters": [{ "name": "orderId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "{ invoiceNumber, issuedAt, currency, grandTotalMinor, state, pdfAvailable }" },
          "404": { "description": "invoice.not_found" }
        }
      }
    },
    "/v1/admin/invoices/": {
      "get": {
        "summary": "Admin invoice list (FR-007)",
        "parameters": [
          { "name": "market", "in": "query", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "from", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "to", "in": "query", "schema": { "type": "string", "format": "date-time" } }
        ],
        "responses": { "200": { "description": "Paginated invoices" } }
      }
    },
    "/v1/admin/invoices/{id}": {
      "get": {
        "summary": "Admin invoice detail incl. credit notes",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": { "200": { "description": "Invoice + lines + credit notes" }, "404": { "description": "invoice.not_found" } }
      }
    },
    "/v1/admin/invoices/by-number/{invoiceNumber}": {
      "get": {
        "summary": "Find invoice by number (FR-018)",
        "parameters": [{ "name": "invoiceNumber", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Invoice id" }, "404": { "description": "invoice.not_found" } }
      }
    },
    "/v1/admin/invoices/{id}/pdf": {
      "get": {
        "summary": "Admin preview of stored PDF (F3)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "PDF stream", "content": { "application/pdf": {} } },
          "409": { "description": "invoice.not_rendered" }
        }
      }
    },
    "/v1/admin/invoices/{id}/resend": {
      "post": {
        "summary": "Resend invoice notification with same stored PDF (FR-007)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "channel": { "type": "string", "enum": ["email", "whatsapp"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Resend queued" },
          "409": { "description": "invoice.not_rendered" }
        }
      }
    },
    "/v1/admin/invoices/{id}/regenerate": {
      "post": {
        "summary": "Re-render PDF (same number, new SHA) — FR-010 / FR-015",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["reason"],
                "properties": { "reason": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Render queued" },
          "400": { "description": "invoice.regenerate.denied" }
        }
      }
    },
    "/v1/admin/invoices/export": {
      "get": {
        "summary": "Streaming finance CSV with credit-note adjustments (FR-014)",
        "parameters": [
          { "name": "market", "in": "query", "schema": { "type": "string" } },
          { "name": "from", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "to", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "format", "in": "query", "schema": { "type": "string", "enum": ["csv"] } }
        ],
        "responses": { "200": { "description": "CSV stream", "content": { "text/csv": {} } } }
      }
    },
    "/v1/admin/invoices/render-queue": {
      "get": {
        "summary": "Stuck-jobs inspector (FR-013)",
        "responses": { "200": { "description": "Queued + failed jobs" } }
      }
    },
    "/v1/admin/invoices/render-queue/{jobId}/retry": {
      "post": {
        "summary": "Force re-enqueue a render job",
        "parameters": [{ "name": "jobId", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }],
        "responses": { "200": { "description": "Queued" }, "404": { "description": "render_job.not_found" } }
      }
    },
    "/v1/internal/invoices/issue-on-capture": {
      "post": {
        "summary": "Idempotent replay of payment.captured invoice issuance",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object", "required": ["orderId"], "properties": { "orderId": { "type": "string", "format": "uuid" } } }
            }
          }
        },
        "responses": {
          "200": { "description": "{ invoiceId, invoiceNumber }" },
          "404": { "description": "invoice.order_not_found" },
          "409": { "description": "invoice.payment_not_captured | invoice.no_lines" }
        }
      }
    },
    "/v1/internal/credit-notes/issue": {
      "post": {
        "summary": "Idempotent credit-note issuance triggered by spec 013 refund",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["invoiceId", "refundId", "lines", "reasonCode"],
                "properties": {
                  "invoiceId": { "type": "string", "format": "uuid" },
                  "refundId": { "type": "string", "format": "uuid" },
                  "reasonCode": { "type": "string" },
                  "lines": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "invoiceLineId": { "type": "string", "format": "uuid" },
                        "qty": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "{ creditNoteId, creditNoteNumber }" },
          "404": { "description": "invoice.not_found | credit_note.line_not_found" },
          "409": { "description": "credit_note.line_exceeds_invoice" }
        }
      }
    }
  }
}
